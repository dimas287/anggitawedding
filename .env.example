APP_NAME="Anggita Wedding Organizer"

# ⚠️ PRODUCTION: Ubah ke 'production' dan set APP_DEBUG=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# ⚠️ PRODUCTION: Ubah ke 'error' agar log tidak terlalu verbose
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=anggitawedding
DB_USERNAME=root
# ⚠️ PRODUCTION: Gunakan password database yang kuat
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# ⚠️ PRODUCTION: Pastikan SESSION_ENCRYPT=true
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# ⚠️ Gunakan Gmail App Password (bukan password akun biasa)
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="Anggita Wedding Organizer"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google OAuth — Daftarkan redirect URL production di Google Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# ⚠️ PRODUCTION: Ubah ke URL domain production
GOOGLE_REDIRECT_URL=https://yourdomain.com/auth/google/callback

# Midtrans Payment Gateway
# ⚠️ PRODUCTION: Gunakan Server Key & Client Key dari dashboard Midtrans production
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
# ⚠️ PRODUCTION: Ubah ke true saat go-live
MIDTRANS_IS_PRODUCTION=false

# OpenAI API
# ⚠️ JANGAN commit file .env ke repository — API key ini bersifat rahasia
OPENAI_API_KEY=your-openai-api-key

VITE_APP_NAME="${APP_NAME}"
VITE_MIDTRANS_CLIENT_KEY="${MIDTRANS_CLIENT_KEY}"
